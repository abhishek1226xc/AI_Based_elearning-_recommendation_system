# -----------------------------------------------------------------------------
# Local development defaults (works without external API keys)
# -----------------------------------------------------------------------------
NODE_ENV=development
DATABASE_URL=./data/elearning.db
JWT_SECRET=dev-local-session-secret-change-me
OWNER_OPEN_ID=dev-user

# App identity (only needed for OAuth callback flow)
VITE_APP_ID=local-app
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=

# Optional AI providers (leave blank to use local AI fallback mode)
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Keep true/empty for local fallback responses when AI keys are missing
LOCAL_AI_FALLBACK=true

# Optional Forge/Biz AI endpoint used by /api/chat
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional analytics
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
