# Database
DATABASE_URL=mysql://user:password@localhost:3306/elearning
DATABASE_PATH=./data/elearning.db

# Authentication
JWT_SECRET=your-jwt-secret-here
OAUTH_SERVER_URL=https://your-oauth-server
OWNER_OPEN_ID=your-owner-open-id
OWNER_EMAIL=owner@example.com

# Client-side (VITE_ prefix exposes to browser)
VITE_APP_ID=your-app-id
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal

# AI / Forge API
BUILT_IN_FORGE_API_URL=https://your-forge-api
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# AI providers
OPENAI_API_KEY=sk-your-openai-key
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Optional
PORT=3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Analytics (optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
